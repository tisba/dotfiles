#!/usr/bin/env bash

set -e

GREEN='\033[0;32m'
NC='\033[0m'

function step() {
  echo -e "${GREEN}██████████${NC} 🔧 ${GREEN}$1${NC}"
}

step "brew Updates"
# FIXME: The HOMEBREW_NO_ASKcan be removed, when https://github.com/Homebrew/brew/pull/22601
#        landed in homebrew.
HOMEBREW_NO_ASK=yes brew upgrade

step "Rust Updates"
rustup update

step "brew Cleanup"
brew_cache=$(brew --cache)
# -s is for scrubbing the cache
brew cleanup -s --verbose && rm -rf "${brew_cache:?}"/*

step "brew doctor"
brew doctor --quiet

step "Update Rubygems"
gem update --system

step "Updating OMZ"
"$ZSH/tools/upgrade.sh"

step "Updating ruby-install available Rubies"
ruby-install --update

step "Updating rubygems and bundler"
gem update --system
gem install bundler

step "Installing/Updating some gems..."
gem install \
  gem-clone \
  solargraph \
  webrick
